# agent-composer — example environment file.
#
# Copy it and edit:   cp .env.example .env
#
# IMPORTANT: `ac` does NOT read this file automatically. Make it take effect by
# either sourcing it into your shell, or letting direnv load it:
#
#     source .env          # once per shell, in this directory
#   — or, with direnv —
#     direnv allow         # auto-loads on `cd` into this directory
#
# See docs/installation.md → "Local development environment" for the full setup.
# Lines keep the `export` prefix so a plain `source .env` exports them; direnv's
# `dotenv` reads this format too.

# --- Default provider + model -------------------------------------------------
# Which provider/model an AGENT node uses when it doesn't pin its own.
# Provider is one of: ollama | anthropic | openai | google
export AGENT_COMPOSER_DEFAULT_PROVIDER=ollama
export AGENT_COMPOSER_DEFAULT_MODEL=qwen3.5:4b

# --- Ollama (local models, no API key) ----------------------------------------
# Point at a running Ollama endpoint. No key needed.
export OLLAMA_BASE_URL=http://localhost:11434

# --- Anthropic (Claude) — uncomment to use ------------------------------------
# export AGENT_COMPOSER_DEFAULT_PROVIDER=anthropic
# export AGENT_COMPOSER_DEFAULT_MODEL=claude-sonnet-4-5
# export ANTHROPIC_API_KEY=sk-ant-...

# --- OpenAI (GPT) — uncomment to use ------------------------------------------
# export AGENT_COMPOSER_DEFAULT_PROVIDER=openai
# export AGENT_COMPOSER_DEFAULT_MODEL=gpt-5.5
# export OPENAI_API_KEY=sk-...

# --- Google (Gemini) — uncomment to use ---------------------------------------
# export AGENT_COMPOSER_DEFAULT_PROVIDER=google
# export AGENT_COMPOSER_DEFAULT_MODEL=gemini-3.5-flash
# export GOOGLE_API_KEY=...
